# Option A: Full Firebase service account JSON as a single-line string.
#FIREBASE_SERVICE_ACCOUNT=""

# Option B: Individual Firebase credentials (recommended for RunPod).
# These are the same values from your Firebase service account JSON.
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
# Optional extras:
# FIREBASE_PRIVATE_KEY_ID=""
# FIREBASE_CLIENT_ID=""
# FIREBASE_CLIENT_CERT_URL=""
# FIREBASE_STORAGE_BUCKET=""  # defaults to {FIREBASE_PROJECT_ID}.firebasestorage.app

# Required: OpenAI API key for AI analysis.
OPENAI_API_KEY=""

# Optional: Node environment (production / development).
NODE_ENV=production

# Optional: service port. Must match the Container Port configured in RunPod.
PORT=8080

# Optional: Chrome binary path. The Dockerfile installs Google Chrome Stable
# and sets this automatically; you normally do not need to override it.
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
