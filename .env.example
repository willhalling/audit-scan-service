# Required: Firebase service account JSON as a single-line string.
# In RunPod, paste the full JSON into the endpoint environment variable.
FIREBASE_SERVICE_ACCOUNT=""

# Required: OpenAI API key for AI analysis.
OPENAI_API_KEY=""

# Optional: Node environment (production / development).
NODE_ENV=production

# Optional: service port. Must match the Container Port configured in RunPod.
PORT=8080

# Optional: Chrome binary path. The Dockerfile installs Google Chrome Stable
# and sets this automatically; you normally do not need to override it.
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
