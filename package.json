{
  "name": "scan-service",
  "version": "1.0.0",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:dev": "npm run build && node dist/index.js",
    "dev": "npm run build && node --inspect dist/index.js",
    "watch": "tsc --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "deploy": "echo '❌ Use deploy:staging or deploy:production instead'",
    "deploy:staging": "sh ./deploy-staging.sh",
    "deploy:production": "sh ./deploy.sh production",
    "healthcheck": "node healthcheck.js",
    "healthcheck:port": "node healthcheck.js",
    "start:debug": "node --trace-warnings dist/index.js",
    "docker:debug": "sh ./debug-local.sh"
  },
  "dependencies": {
    "@sparticuz/chromium": "^121.0.0",
    "axe-core": "^4.10.3",
    "axios": "^1.6.7",
    "canvas": "^2.11.2",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "firebase-admin": "^12.0.0",
    "lighthouse": "^12.6.1",
    "openai": "^4.28.4",
    "p-retry": "^6.2.0",
    "pdf-lib": "^1.17.1",
    "puppeteer-core": "22.0.0",
    "sharp": "^0.33.5",
    "user-agents": "^1.1.174",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "@types/user-agents": "^1.0.4",
    "@types/uuid": "^9.0.8",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.0.0"
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}
